# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=change-this-to-a-random-secret

# Database Configuration (PostgreSQL)
# Set this to your Render PostgreSQL connection string in production
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/qrdocument

# CORS Configuration (comma-separated or *)
CORS_ORIGIN=*

# Public URL for QR codes (set to your Render URL in production)
PUBLIC_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
